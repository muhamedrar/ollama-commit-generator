{ "icon": "images/ollamaIcon.png",
  "name": "kodecommit",
  "displayName": "KodeCommit",
  "description": "Generate Git commit messages from Source Control with OpenAI. KODE stands for Keep Our Diffs Explained.",
  "version": "1.0.0",
  "license": "MIT",
  "publisher": "local",
  "keywords": [
    "git",
    "commit",
    "commit-message",
    "source-control",
    "vscode",
    "openai",
    "cohere",
    "ollama",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/user/KodeCommit"
  },
  "scripts": {
    "package-vsix": "bash ./package-vsix.sh"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "*"
  ],
  "main": "extension.js",
  "categories": [
    "Source Control"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kodeCommit.generateCommitMessage",
        "title": "Generate Commit Message",
        "category": "KodeCommit",
        "icon": {
          "light": "images/magic-wand.png",
          "dark": "images/magic-wand-dark2.png"
        }
      },
      {
        "command": "kodeCommit.chooseModel",
        "title": "Choose AI Model",
        "category": "KodeCommit"
      },
      {
        "command": "kodeCommit.configureProvider",
        "title": "AI Settings",
        "category": "KodeCommit",
        "icon": {
          "light": "images/settings-light.svg",
          "dark": "images/settings-dark.png"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "kodeCommit.generateCommitMessage",
          "group": "navigation"
        },
        {
          "command": "kodeCommit.configureProvider",
          "group": "navigation"
        }
      ]
    }
  }
}
