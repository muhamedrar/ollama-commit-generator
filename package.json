{
  "name": "ollama-commit-generator",
  "displayName": "Ollama Commit Generator",
  "description": "Add a Source Control button and model picker for local or endpoint-based Ollama commit message generation.",
  "version": "0.0.1",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/ollama-commit-generator"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "*"
  ],
  "main": "extension.js",
  "categories": [
    "Source Control"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ollamaCommit.generateCommitMessage",
        "title": "Generate Commit Message",
        "category": "Ollama Commit Generator",
        "icon": {
          "light": "images/ollama.svg",
          "dark": "images/ollama.svg"
        }
      },
      {
        "command": "ollamaCommit.chooseModel",
        "title": "Choose Ollama Model",
        "category": "Ollama Commit Generator"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "ollamaCommit.generateCommitMessage",
          "group": "navigation"
        },
        {
          "command": "ollamaCommit.chooseModel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Ollama Commit Generator",
      "properties": {
        "ollamaCommit.ollamaPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Ollama CLI executable. If empty, the extension will search PATH.",
          "scope": "machine"
        },
        "ollamaCommit.endpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "URL of the Ollama HTTP endpoint (for containerized Ollama). If set, the extension will call the endpoint instead of the local CLI.",
          "scope": "machine"
        },
        "ollamaCommit.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional Bearer token for the Ollama endpoint.",
          "scope": "machine"
        }
      }
    }
  }
}
