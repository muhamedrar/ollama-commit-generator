{ "icon": "images/ollamaIcon.png",
  "name": "ollama-commit-generator",
  "displayName": "LlamaCommit",
  "description": "Generate Git commit messages from Ollama, OpenAI-compatible endpoints, or Cohere directly from Source Control.",
  "version": "0.0.1",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/ollama-commit-generator"
  },
  "scripts": {
    "package-vsix": "yes | npx @vscode/vsce package --allow-star-activation"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "*"
  ],
  "main": "extension.js",
  "categories": [
    "Source Control"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ollamaCommit.generateCommitMessage",
        "title": "Generate Commit Message",
        "category": "LlamaCommit",
        "icon": {
          "light": "images/magic-wand.png",
          "dark": "images/magic-wand-dark.png"
        }
      },
      {
        "command": "ollamaCommit.chooseModel",
        "title": "Choose AI Model",
        "category": "LlamaCommit"
      },
      {
        "command": "ollamaCommit.configureProvider",
        "title": "AI Settings",
        "category": "LlamaCommit",
        "icon": {
          "light": "images/settings-light.svg",
          "dark": "images/settings-dark.png"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "ollamaCommit.generateCommitMessage",
          "group": "navigation"
        },
        {
          "command": "ollamaCommit.configureProvider",
          "group": "navigation"
        }
      ]
    }
  }
}
